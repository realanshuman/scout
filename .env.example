# ── Core ────────────────────────────────────────────────────────────
NODE_ENV=development
API_PORT=4000
# Public URL of the API (used for payment webhooks / WhatsApp callbacks)
API_PUBLIC_URL=http://localhost:4000
# Public URL of the dashboard
WEB_PUBLIC_URL=http://localhost:3000

# ── OpenAI ──────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
# Default chat/agent model (Responses API)
OPENAI_MODEL=gpt-5.5
# Cheaper model for extraction / classification steps
OPENAI_FAST_MODEL=gpt-5.5-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Supabase ────────────────────────────────────────────────────────
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── WhatsApp (Meta Business Cloud API) ─────────────────────────────
WHATSAPP_PHONE_NUMBER_ID=123456789
WHATSAPP_ACCESS_TOKEN=EAAG...
# Any random string; must match what you enter in the Meta webhook config
WHATSAPP_VERIFY_TOKEN=scout-verify-token
# Deep-link number shown on the dashboard (E.164, no +)
NEXT_PUBLIC_WHATSAPP_NUMBER=15551234567

# ── Search / scraping ──────────────────────────────────────────────
TAVILY_API_KEY=tvly-...
FIRECRAWL_API_KEY=fc-...

# ── Payments (Dodo Payments — merchant of record) ──────────────────
DODO_PAYMENTS_API_KEY=...
# Webhook signing key from Dashboard → Webhooks (whsec_...)
DODO_PAYMENTS_WEBHOOK_KEY=whsec_...
# One-time product for the full investor report (₹999 / $29)
DODO_PAYMENTS_PRODUCT_ID=pdt_...
# test_mode (default) or live_mode
DODO_PAYMENTS_ENVIRONMENT=test_mode

# ── Queue (optional — falls back to in-process jobs when unset) ────
REDIS_URL=redis://localhost:6379

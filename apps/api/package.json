{
  "name": "@scout/api",
  "version": "0.1.0",
  "private": true,
  "description": "Scout backend — WhatsApp webhook + agent pipeline",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "dev": "node -r ts-node/register -r dotenv/config src/main.ts",
    "lint": "tsc -p tsconfig.build.json --noEmit",
    "seed:investors": "node -r ts-node/register -r dotenv/config scripts/seed-investors.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@supabase/supabase-js": "^2.45.0",
    "bullmq": "^5.34.0",
    "dodopayments": "^2.42.0",
    "dotenv": "^16.4.0",
    "openai": "^5.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.0"
  }
